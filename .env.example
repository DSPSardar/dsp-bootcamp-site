# Google Sheets integration for lead capture
# Get this from: Extensions → Apps Script → Deploy → Web app
# Copy the full deployment URL
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional — if set, leads are emailed to LEAD_EMAIL via Resend
RESEND_API_KEY=
LEAD_EMAIL=

# GA4 measurement ID (G-XXXXXXXXXX). Analytics load only when this is set.
NEXT_PUBLIC_GA4_ID=
